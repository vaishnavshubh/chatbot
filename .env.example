# Copy to `.env` and edit. Do not commit `.env`.
#
# Streamlit Community Cloud: use App settings → Secrets (see `.streamlit/secrets.toml.example`).
#
# Primary setup: Gemma 4 on the Gemini API (matches app defaults in app/llm_backend.py).

# --- Google Gemini API + Gemma 4 (google-genai SDK) ---
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Default Gemma 4 instruct model; override with e.g. gemma-4-31b-it if your quota allows
LLM_MODEL=gemma-4-26b-a4b-it

# When GEMINI_API_KEY (or GOOGLE_API_KEY) is set, OPENAI_* is ignored for LLM calls.
# Comment out GEMINI_API_KEY and set OPENAI_* below to use OpenAI or Ollama instead.

# --- OpenAI cloud or local Ollama (OpenAI-compatible Chat Completions) ---
# GEMINI_API_KEY=
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=gemma4:latest

# RAG (Phase 3 & 4 grounding): 1=on, 0=off
RAG_ENABLED=1
RAG_TOP_K=5
