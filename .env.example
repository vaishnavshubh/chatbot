# Copy to `.env` and edit. Do not commit `.env`.
#
# Streamlit Community Cloud: use App settings → Secrets (see `.streamlit/secrets.toml.example`).
#
# Provider priority: NVIDIA_API_KEY > GEMINI_API_KEY > OPENAI_API_KEY.
# Set exactly ONE provider key.

# --- Option A: NVIDIA NIM (OpenAI-compatible, default) ---
# Get a key: https://build.nvidia.com/ → API Catalog → Get API Key
NVIDIA_API_KEY=your-nvidia-api-key
LLM_MODEL=meta/llama-3.3-70b-instruct

# --- Option B: Google Gemini API (google-genai SDK) ---
# GEMINI_API_KEY=your-gemini-api-key
# LLM_MODEL=gemini-2.5-flash

# --- Option C: OpenAI cloud or local Ollama (OpenAI-compatible) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- Option D: Local Ollama ---
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=gemma4:latest

# RAG (Phase 3 & 4 grounding): 1=on, 0=off
RAG_ENABLED=1
RAG_TOP_K=5
