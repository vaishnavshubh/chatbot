# Copy these keys into Streamlit Community Cloud:
#   App settings → Secrets → Edit as TOML
#
# Do not commit real values. For local dev, use `.env` (see `.env.example`).

# --- Option A: Google Gemini API + Gemma (default path in app) ---
GEMINI_API_KEY = "your-gemini-api-key"
LLM_MODEL = "gemma-4-26b-a4b-it"

# --- Option B: OpenAI-compatible (OpenAI cloud, Ollama, vLLM, etc.) ---
# Leave GEMINI_API_KEY unset in Cloud UI (delete the line or use empty — prefer delete).
# OPENAI_API_KEY = "sk-..."
# OPENAI_BASE_URL = "https://api.openai.com/v1"
# LLM_MODEL = "gpt-4o-mini"

# RAG (optional)
RAG_ENABLED = "1"
RAG_TOP_K = "5"
