# Copy these keys into Streamlit Community Cloud:
#   App settings → Secrets → Edit as TOML
#
# Do not commit real values. For local dev, use `.env` (see `.env.example`).
# Provider priority: NVIDIA_API_KEY > GEMINI_API_KEY > OPENAI_API_KEY.

# --- Option A: NVIDIA NIM (default) ---
NVIDIA_API_KEY = "nvapi-..."
LLM_MODEL = "meta/llama-3.3-70b-instruct"

# --- Option B: Google Gemini API ---
# GEMINI_API_KEY = "your-gemini-api-key"
# LLM_MODEL = "gemini-2.5-flash"

# --- Option C: OpenAI-compatible (OpenAI cloud, Ollama, vLLM, etc.) ---
# OPENAI_API_KEY = "sk-..."
# OPENAI_BASE_URL = "https://api.openai.com/v1"
# LLM_MODEL = "gpt-4o-mini"

# RAG (optional)
RAG_ENABLED = "1"
RAG_PROFILE = "fast"
# RAG_TOP_K = "2"
RAG_BACKEND = "jsonl"
# RAG_VECTOR_COLLECTION = "finlit_hard_rules"
